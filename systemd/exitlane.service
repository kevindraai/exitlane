[Unit]
Description=Exitlane egress gateway
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
EnvironmentFile=-/etc/default/exitlane
WorkingDirectory=/opt/exitlane/backend
ExecStart=/opt/exitlane/venv/bin/uvicorn exitlane.main:app --host ${EXITLANE_HOST} --port ${EXITLANE_PORT}
Restart=on-failure
RestartSec=5
UMask=0077

[Install]
WantedBy=multi-user.target
